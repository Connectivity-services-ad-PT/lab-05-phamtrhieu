# ── Service ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8100
SERVICE_NAME=team-notify
SERVICE_VERSION=1.0.0

# ── MQTT (lấy thông tin từ README kết nối chung của lớp) ──
MQTT_BROKER=mqtt-broker          # tên container hoặc IP broker
MQTT_PORT=1883
MQTT_USERNAME=                   # để trống nếu không có auth
MQTT_PASSWORD=
MQTT_ALERT_TOPIC=smart-campus/events/alert

# ── Telegram (không commit token thật) ───────────
TELEGRAM_BOT_TOKEN=              # token bot từ @BotFather
TELEGRAM_CHAT_ID=                # chat_id nhóm security_team
TELEGRAM_ADMIN_CHAT_ID=          # chat_id riêng cho admin

# ── Email / SMTP ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # địa chỉ email gửi đi
SMTP_PASSWORD=                   # App Password (không dùng mật khẩu tài khoản)
EMAIL_SECURITY_TEAM=             # email nhận cho security_team
EMAIL_ADMIN=                     # email nhận cho admin

# ── Hành vi nghiệp vụ ─────────────────────────────
MAX_RETRY=3                      # số lần retry tối đa
RETRY_DELAY_BASE=2.0             # giây, tăng theo exponential backoff
DEDUP_WINDOW=300                 # giây chống gửi trùng cùng alert_id
